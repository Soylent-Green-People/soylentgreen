<UserControl x:Class="LocalPilot.Options.LocalPilotOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="700">

    <UserControl.Resources>

        <SolidColorBrush x:Key="A0" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="A1" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="A2" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="A3" Color="#CCCCCC"/>

        <Style x:Key="S0" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource A0}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource A3}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="S1" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource A1}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="S2" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource A2}"/>
            <Setter Property="Foreground" Value="{DynamicResource A1}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource A3}"
                                BorderThickness="1"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource A3}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="S3" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource A0}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource A3}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="S4" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TabPanel Grid.Row="0" IsItemsHost="True"/>

                            <Border Grid.Row="1"
                                    Background="{DynamicResource A0}"
                                    BorderBrush="{DynamicResource A3}"
                                    BorderThickness="1">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="{DynamicResource A0}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource S0}"
                Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="LocalPilot"
                           Style="{StaticResource S1}"
                           FontWeight="Bold"/>
                <TextBlock Text="   "
                           Style="{StaticResource S1}"/>
                <TextBlock Text="Local Assistant"
                           Style="{StaticResource S1}"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    Style="{StaticResource S4}">

            <TabItem Header="General">
                <ScrollViewer>
                    <StackPanel Margin="10">

                        <TextBlock Text="Connection"
                                   Style="{StaticResource S1}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Style="{StaticResource S3}"
                                     Text="http://localhost:11434"/>

                            <Button Grid.Column="1"
                                    Content="Test"
                                    Style="{StaticResource S2}"
                                    Margin="10,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Models"
                                   Margin="0,20,0,0"
                                   Style="{StaticResource S1}"/>

                        <ComboBox Height="25"/>
                        <ComboBox Height="25"/>
                        <ComboBox Height="25"/>

                        <Button Content="Refresh"
                                Style="{StaticResource S2}"
                                Margin="0,10,0,0"/>

                        <CheckBox Content="Enable inline completion"/>
                        <CheckBox Content="Show preview"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Advanced">
                <ScrollViewer>
                    <StackPanel Margin="10">

                        <TextBlock Text="Performance"
                                   Style="{StaticResource S1}"/>

                        <ComboBox>
                            <ComboBoxItem Content="Fast"/>
                            <ComboBoxItem Content="Balanced"/>
                            <ComboBoxItem Content="Accurate"/>
                        </ComboBox>

                        <TextBlock Text="History"
                                   Margin="0,20,0,0"
                                   Style="{StaticResource S1}"/>

                        <TextBox Style="{StaticResource S3}"
                                 Width="100"/>

                        <CheckBox Content="Enable project map"/>

                        <Slider Minimum="1"
                                Maximum="10"
                                Value="3"
                                Width="200"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2"
                Style="{StaticResource S0}"
                Padding="10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Save"
                        Style="{StaticResource S2}"
                        Width="120"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
